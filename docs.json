{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "StatusPage.one",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "getting-started/introduction"]
          },
          {
            "group": "Monitoring",
            "pages": [
              "monitoring/monitors-overview",
              "monitoring/creating-monitors",
              "monitoring/monitor-statistics",
              "monitoring/monitor-alerts"
            ]
          },
          {
            "group": "Status Pages",
            "pages": [
              "status-pages/overview",
              "status-pages/components",
              "status-pages/custom-domains",
              "status-pages/badges"
            ]
          },
          {
            "group": "Incidents & Maintenance",
            "pages": [
              "incidents-maintenance/incidents",
              "incidents-maintenance/incident-updates",
              "incidents-maintenance/maintenance",
              "incidents-maintenance/maintenance-updates"
            ]
          },
          {
            "group": "Notifications",
            "pages": [
              "notifications/alert-rules",
              "notifications/integrations",
              "notifications/notification-channels"
            ]
          },
          {
            "group": "Organization",
            "pages": ["organization/team-members", "organization/settings"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Site",
          "href": "https://statuspageone.com",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://statuspageone.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://console.statuspageone.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/statuspageone",
      "github": "https://github.com/statuspageone",
      "linkedin": "https://linkedin.com/company/statuspageone"
    }
  }
}
